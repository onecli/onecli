# Database (optional — if not set, uses embedded PGlite)
# DATABASE_URL=postgresql://user:password@localhost:5432/onecli

# Auth — single-user mode by default (no login required).
# To enable Google OAuth login (multi-user), set NEXTAUTH_SECRET and the Google credentials below.
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=

# Google OAuth (for login — works in both auth modes)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# Secret encryption key for encrypting stored secrets (API keys, tokens, etc.)
# Auto-generated on first container start if not set.
# Only set this if you need a specific key (e.g., migrating data between instances).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SECRET_ENCRYPTION_KEY=change-me-to-secure-key

# Secret provider backend.
# local_db: encrypted values stored in database (default)
# vault_hcp: secret values stored in HashiCorp Vault Enterprise KV v2
SECRET_PROVIDER=local_db

# Vault settings (required when SECRET_PROVIDER=vault_hcp)
VAULT_ADDR=
VAULT_TOKEN=
VAULT_NAMESPACE=
VAULT_KV_MOUNT=secret
VAULT_KV_PREFIX=onecli

# Local Docker Vault dev mode token (used by docker-compose vault and vault-init services)
VAULT_DEV_ROOT_TOKEN_ID=root

# Local Docker production-like Vault profile endpoint.
# When running `docker compose --profile vault-prod up`, Vault listens on localhost:18200.
VAULT_PROD_ADDR=http://localhost:18200

# One-shot quick agent test (docker compose --profile quick-agent run --rm quick-agent)
# Copy from Dashboard -> Agents -> token
ONECLI_AGENT_TOKEN=
TARGET_URL_BEARER=https://httpbin.org/bearer
TARGET_URL_ANYTHING=https://httpbin.org/anything
