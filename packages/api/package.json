{
  "name": "@onecli/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./providers": "./src/providers/index.ts",
    "./services/*": "./src/services/*.ts",
    "./lib/*": "./src/lib/*.ts",
    "./validations/*": "./src/validations/*.ts",
    "./apps/*": "./src/apps/*.ts",
    "./apps/app-permissions": "./src/apps/app-permissions/index.ts",
    "./apps/app-permissions/*": "./src/apps/app-permissions/*.ts",
    "./apps/oauth/*": "./src/apps/oauth/*.ts",
    "./ee": "./src/ee/index.ts",
    "./ee/*": "./src/ee/*.ts",
    "./ee/services/*": "./src/ee/services/*.ts",
    "./ee/clients/*": "./src/ee/clients/*.ts",
    "./ee/billing/*": "./src/ee/billing/*.ts",
    "./ee/notifications/*": "./src/ee/notifications/*.ts",
    "./ee/apps/*": "./src/ee/apps/*.ts",
    "./ee/apps/app-permissions/*": "./src/ee/apps/app-permissions/*.ts",
    "./ee/auth/*": "./src/ee/auth/*.ts",
    "./ee/partner/*": "./src/ee/partner/*.ts",
    "./ee/granular-access": "./src/ee/granular-access/index.ts"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "lint": "eslint --max-warnings 0",
    "lint:fix": "eslint --fix --max-warnings 0",
    "test": "vitest run"
  },
  "dependencies": {
    "@1password/sdk": "^0.4.0",
    "@aws-sdk/client-kms": "^3.1014.0",
    "@aws-sdk/client-secrets-manager": "^3.1014.0",
    "@onecli/db": "workspace:*",
    "hono": "^4.12.0",
    "ioredis": "^5.10.1",
    "nanoid": "^5.1.9",
    "pino": "^10.3.1",
    "stripe": "^20.4.0",
    "tldts": "^7.4.4",
    "undici": "^8.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@onecli/eslint-config": "workspace:*",
    "@onecli/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "pino-pretty": "^13.1.3",
    "typescript": "5.9.2",
    "vitest": "^3.2.6"
  }
}
